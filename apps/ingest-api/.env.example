# Puerto en el que escucha la API Go
HTTP_ADDR=:8080

# Dirección de ClickHouse usando el protocolo nativo (TCP, puerto 9000)
# Más rápido que la interfaz HTTP (8123) para inserciones desde Go
CLICKHOUSE_ADDR=localhost:9000

# Credenciales de ClickHouse (deben coincidir con docker-compose.yml)
CLICKHOUSE_DB=iseeyou
CLICKHOUSE_USER=iseeyou
CLICKHOUSE_PASSWORD=iseeyou_secret
