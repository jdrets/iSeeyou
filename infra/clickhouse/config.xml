<clickhouse>
    <!-- Bind only on all interfaces in dev. In prod restrict to specific IPs. -->
    <listen_host>0.0.0.0</listen_host>

    <!-- Max connections tuned for moderate dev resources -->
    <max_connections>100</max_connections>
    <max_concurrent_queries>50</max_concurrent_queries>

    <!-- Logs menos verbosos en dev -->
    <!-- Nota: max_memory_usage y async_insert_* son user-level settings;
         van en users.xml dentro de <profiles>, no aquí. -->
    <logger>
        <level>warning</level>
        <console>1</console>
    </logger>
</clickhouse>
