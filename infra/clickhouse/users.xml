<clickhouse>
    <users>
        <seeyou>
            <!-- En producción usar bcrypt hash en lugar de plaintext -->
            <password>seeyou_secret</password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
            <named_collection_control>1</named_collection_control>
        </seeyou>
    </users>

    <profiles>
        <default>
            <!-- Async inserts habilitados por defecto para el usuario seeyou -->
            <async_insert>1</async_insert>
            <wait_for_async_insert>0</wait_for_async_insert>
            <async_insert_max_data_size>10485760</async_insert_max_data_size>
            <async_insert_busy_timeout_ms>200</async_insert_busy_timeout_ms>
        </default>
    </profiles>
</clickhouse>
